# ============================================================
# TAKASON - Çevresel Değişkenler
# Bu dosyayı .env olarak kopyala ve değerleri doldur
# ASLA bu dosyayı .env ile birlikte git'e push etme!
# ============================================================

# Sunucu
NODE_ENV=development
PORT=5000

# Veritabanı (PostgreSQL)
# Hostinger: Database > Manage > Connection String
DATABASE_URL="postgresql://KULLANICI:SIFRE@HOST:5432/VERITABANI_ADI?schema=public"

# JWT Gizli Anahtarı - En az 64 karakter, rastgele üret!
# Üretmek için: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
JWT_SECRET="BURAYA_COK_GUCLU_VE_RASTGELE_BIR_ANAHTAR_YAZ"
JWT_EXPIRES_IN="7d"
JWT_REFRESH_SECRET="BURAYA_FARKLI_BIR_GUCLU_ANAHTAR_YAZ"
JWT_REFRESH_EXPIRES_IN="30d"

# Redis (Sonraki aşamada aktif edilecek)
# REDIS_URL="redis://localhost:6379"

# CORS - Frontend domain adresleri (virgülle ayır)
ALLOWED_ORIGINS="http://localhost:3000,http://localhost:5173,https://takason.com"

# Medya Yükleme (Şimdilik local, S3'e geçişe hazır)
UPLOAD_DIR="uploads"
MAX_FILE_SIZE=10485760  # 10MB - byte cinsinden
ALLOWED_MIME_TYPES="image/jpeg,image/png,image/webp"

# AWS S3 (İleride aktif edilecek)
# AWS_ACCESS_KEY_ID=""
# AWS_SECRET_ACCESS_KEY=""
# AWS_REGION="eu-west-1"
# AWS_S3_BUCKET=""

# Rate Limiting
RATE_LIMIT_WINDOW_MS=900000  # 15 dakika (milisaniye)
RATE_LIMIT_MAX=100           # 15 dakikada maximum istek sayısı
