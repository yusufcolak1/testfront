// ============================================
// TAKASON - Prisma Schema (SQLite - dev)
// ============================================

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

// ============================================
// USER & PROFILE
// ============================================

model User {
  id           String   @id @default(uuid())
  email        String   @unique
  passwordHash String   @map("password_hash")
  role         String   @default("USER") // USER, ADMIN, MODERATOR
  status       String   @default("ACTIVE") // ACTIVE, BANNED, SUSPENDED
  createdAt    DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")

  profile        Profile?
  items          Item[]
  sentTrades     Trade[]    @relation("SentTrades")
  receivedTrades Trade[]    @relation("ReceivedTrades")
  chatRooms      ChatRoom[]
  messages       Message[]
  favorites      Favorite[]
  addresses      Address[]
  notifications  Notification[]

  @@map("users")
}

model Profile {
  id              String   @id @default(uuid())
  userId          String   @unique @map("user_id")
  firstName       String   @map("first_name")
  lastName        String   @map("last_name")
  phone           String?
  city            String?
  country         String?  @default("Turkey")
  bio             String?
  avatarUrl       String?  @map("avatar_url")
  rating          Float    @default(0.0)
  totalTrades     Int      @default(0) @map("total_trades")
  score           Int      @default(0)
  swapsCompleted  Int      @default(0) @map("swaps_completed")
  medal           String?
  isPremium       Boolean  @default(false) @map("is_premium")
  premiumUntil    DateTime? @map("premium_until")
  createdAt       DateTime @default(now()) @map("created_at")
  updatedAt       DateTime @updatedAt @map("updated_at")

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("profiles")
}

model Address {
  id        String   @id @default(uuid())
  userId    String   @map("user_id")
  title     String
  address   String
  type      String   @default("HOME") // HOME, WORK, OTHER
  city      String?
  isDefault Boolean  @default(false) @map("is_default")
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@map("addresses")
}

// ============================================
// CATEGORY & ITEM
// ============================================

model Category {
  id          String   @id @default(uuid())
  name        String   @unique
  slug        String   @unique
  description String?
  icon        String?
  parentId    String?  @map("parent_id")
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")

  parent   Category?  @relation("CategoryHierarchy", fields: [parentId], references: [id])
  children Category[] @relation("CategoryHierarchy")
  items    Item[]

  @@map("categories")
}

model Item {
  id             String      @id @default(uuid())
  userId         String      @map("user_id")
  categoryId     String      @map("category_id")
  title          String
  description    String
  condition      String      // NEW, LIKE_NEW, GOOD, FAIR, POOR
  status         String      @default("DRAFT") // DRAFT, ACTIVE, SOLD, ARCHIVED, DELETED
  location       String?
  estimatedValue Float?      @map("estimated_value")
  swapFor        String?     @map("swap_for")
  tag            String?     // NEW, FEATURED, POPULAR
  isFeatured     Boolean     @default(false) @map("is_featured")
  isPopular      Boolean     @default(false) @map("is_popular")
  viewCount      Int         @default(0) @map("view_count")
  createdAt      DateTime    @default(now()) @map("created_at")
  updatedAt      DateTime    @updatedAt @map("updated_at")

  user       User        @relation(fields: [userId], references: [id], onDelete: Cascade)
  category   Category    @relation(fields: [categoryId], references: [id])
  images     ItemImage[]
  tradeItems TradeItem[]
  favorites  Favorite[]

  @@index([userId])
  @@index([categoryId])
  @@index([status])
  @@map("items")
}

model ItemImage {
  id           String   @id @default(uuid())
  itemId       String   @map("item_id")
  imageUrl     String   @map("image_url")
  displayOrder Int      @default(0) @map("display_order")
  isPrimary    Boolean  @default(false) @map("is_primary")
  createdAt    DateTime @default(now()) @map("created_at")

  item Item @relation(fields: [itemId], references: [id], onDelete: Cascade)

  @@index([itemId])
  @@map("item_images")
}

// ============================================
// TRADE
// ============================================

model Trade {
  id         String      @id @default(uuid())
  senderId   String      @map("sender_id")
  receiverId String      @map("receiver_id")
  status     String      @default("PENDING") // PENDING, ACCEPTED, REJECTED, COMPLETED, CANCELLED
  message    String?
  createdAt  DateTime    @default(now()) @map("created_at")
  updatedAt  DateTime    @updatedAt @map("updated_at")

  sender     User        @relation("SentTrades", fields: [senderId], references: [id])
  receiver   User        @relation("ReceivedTrades", fields: [receiverId], references: [id])
  tradeItems TradeItem[]

  @@index([senderId])
  @@index([receiverId])
  @@index([status])
  @@map("trades")
}

model TradeItem {
  id        String   @id @default(uuid())
  tradeId   String   @map("trade_id")
  itemId    String   @map("item_id")
  side      String   // OFFER, REQUEST
  createdAt DateTime @default(now()) @map("created_at")

  trade Trade @relation(fields: [tradeId], references: [id], onDelete: Cascade)
  item  Item  @relation(fields: [itemId], references: [id])

  @@unique([tradeId, itemId])
  @@index([tradeId])
  @@index([itemId])
  @@map("trade_items")
}

// ============================================
// CHAT
// ============================================

model ChatRoom {
  id        String    @id @default(uuid())
  userIds   String    @map("user_ids")
  createdAt DateTime  @default(now()) @map("created_at")
  updatedAt DateTime  @updatedAt @map("updated_at")

  users    User[]
  messages Message[]

  @@map("chat_rooms")
}

model Message {
  id         String   @id @default(uuid())
  chatRoomId String   @map("chat_room_id")
  senderId   String   @map("sender_id")
  content    String
  type       String   @default("TEXT")
  isRead     Boolean  @default(false) @map("is_read")
  createdAt  DateTime @default(now()) @map("created_at")

  chatRoom ChatRoom @relation(fields: [chatRoomId], references: [id], onDelete: Cascade)
  sender   User     @relation(fields: [senderId], references: [id])

  @@index([chatRoomId])
  @@index([senderId])
  @@map("messages")
}

// ============================================
// FAVORITE
// ============================================

model Favorite {
  id        String   @id @default(uuid())
  userId    String   @map("user_id")
  itemId    String   @map("item_id")
  createdAt DateTime @default(now()) @map("created_at")

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
  item Item @relation(fields: [itemId], references: [id], onDelete: Cascade)

  @@unique([userId, itemId])
  @@index([userId])
  @@index([itemId])
  @@map("favorites")
}

// ============================================
// CONTENT (CMS-like - admin yönetir)
// ============================================

model FAQ {
  id        String   @id @default(uuid())
  question  String
  answer    String
  category  String?
  order     Int      @default(0)
  isActive  Boolean  @default(true) @map("is_active")
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  @@map("faqs")
}

model HelpCategory {
  id          String   @id @default(uuid())
  title       String
  description String
  icon        String   @default("HelpCircle")
  order       Int      @default(0)
  isActive    Boolean  @default(true) @map("is_active")
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")

  @@map("help_categories")
}

model PremiumPerk {
  id          String   @id @default(uuid())
  title       String
  value       String?  // örn. "AKTİF", "3/10"
  description String
  icon        String   @default("Sparkles")
  color       String   @default("text-amber-500")
  order       Int      @default(0)
  isActive    Boolean  @default(true) @map("is_active")
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")

  @@map("premium_perks")
}

model PremiumPlan {
  id          String   @id @default(uuid())
  name        String
  price       Float
  period      String   @default("MONTHLY") // MONTHLY, YEARLY
  description String?
  features    String   // JSON-encoded string array
  order       Int      @default(0)
  isActive    Boolean  @default(true) @map("is_active")
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")

  @@map("premium_plans")
}

model SafeSwapStep {
  id          String   @id @default(uuid())
  title       String
  description String
  icon        String   @default("Shield")
  order       Int      @default(0)
  isActive    Boolean  @default(true) @map("is_active")
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")

  @@map("safe_swap_steps")
}

// ============================================
// SETTINGS (key/value, admin paneli ile yönetilir)
// ============================================

model SiteSetting {
  id          String   @id @default(uuid())
  key         String   @unique
  value       String
  type        String   @default("STRING") // STRING, JSON, BOOLEAN, NUMBER
  group       String   @default("general") // general, smtp, sms, cloudinary, premium, theme
  description String?
  isPublic    Boolean  @default(false) @map("is_public")
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")

  @@index([group])
  @@map("site_settings")
}

// ============================================
// NOTIFICATION
// ============================================

model Notification {
  id        String   @id @default(uuid())
  userId    String   @map("user_id")
  type      String   @default("SYSTEM") // SYSTEM, TRADE, MESSAGE, INFO
  title     String
  body      String
  link      String?
  isRead    Boolean  @default(false) @map("is_read")
  createdAt DateTime @default(now()) @map("created_at")

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@map("notifications")
}
