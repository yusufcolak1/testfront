// ============================================================
// TAKASON - Prisma Veritabanı Şeması (MySQL)
// MySQL + Prisma ORM
// Üretim kalitesi - 100.000 aktif kullanıcıya ölçeklenebilir
// ============================================================

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "mysql"
  url      = env("DATABASE_URL")
}

// ============================================================
// 1. KULLANICI YÖNETİMİ
// ============================================================

// Kimlik doğrulama verilerini tutar (login yükünü hafifletmek için profil ayrı tabloda)
model User {
  id           String      @id @default(uuid())
  email        String      @unique
  passwordHash String      @map("password_hash") @db.VarChar(255)
  role         String      @default("USER") @db.VarChar(50)
  status       String      @default("ACTIVE") @db.VarChar(50)
  createdAt    DateTime    @default(now()) @map("created_at")
  updatedAt    DateTime    @updatedAt @map("updated_at")

  // İlişkiler
  profile         UserProfile?
  items           Item[]
  initiatedTrades Trade[]      @relation("TradeInitiator")
  receivedTrades  Trade[]      @relation("TradeReceiver")
  sentMessages    Message[]    @relation("MessageSender")
  chatRoomsAsBuyer   ChatRoom[] @relation("ChatBuyer")
  chatRoomsAsSeller  ChatRoom[] @relation("ChatSeller")
  favorites       Favorite[]

  @@map("users")
}

// UserRole: USER, ADMIN, MODERATOR
// UserStatus: ACTIVE, BANNED, SUSPENDED

// Kullanıcı profil verileri - sorgularda lazım olmadıkça JOIN yapılmaz
model UserProfile {
  id          String   @id @default(uuid())
  userId      String   @unique @map("user_id")
  firstName   String   @map("first_name") @db.VarChar(100)
  lastName    String   @map("last_name") @db.VarChar(100)
  phone       String?  @db.VarChar(20)
  city        String?  @db.VarChar(100)
  district    String?  @db.VarChar(100)
  avatarUrl   String?  @map("avatar_url") @db.VarChar(500)
  trustScore  Float    @default(0) @map("trust_score")
  bio         String?  @db.Text
  premiumUntil DateTime? @map("premium_until")
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")

  // İlişkiler
  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("user_profiles")
}

// ============================================================
// 2. KATEGORİ YÖNETİMİ (Alt kategori destekli - Self Relation)
// ============================================================

model Category {
  id       String  @id @default(uuid())
  name     String  @db.VarChar(100)
  slug     String  @unique @db.VarChar(150)
  imageUrl String? @map("image_url") @db.VarChar(500)
  parentId String? @map("parent_id")
  order    Int     @default(0)
  isActive Boolean @default(true) @map("is_active")

  // Self-relation: alt kategoriler için (Elektronik -> Telefon -> iPhone)
  parent   Category?  @relation("CategoryChildren", fields: [parentId], references: [id])
  children Category[] @relation("CategoryChildren")

  // İlişkiler
  items Item[]

  @@map("categories")
}

// ============================================================
// 3. İLAN YÖNETİMİ
// ============================================================

model Item {
  id          String      @id @default(uuid())
  userId      String      @map("user_id")
  categoryId  String      @map("category_id")
  title       String      @db.VarChar(200)
  description String      @db.Text
  condition   String      @db.VarChar(50)
  status      String      @default("ACTIVE") @db.VarChar(50)
  viewCount   Int         @default(0) @map("view_count")
  city        String?     @db.VarChar(100)
  district    String?     @db.VarChar(100)
  // Tahmini değer - takas tekliflerinde kullanılır
  estimatedValue Float?   @map("estimated_value")
  createdAt   DateTime    @default(now()) @map("created_at")
  updatedAt   DateTime    @updatedAt @map("updated_at")

  // İlişkiler
  user       User        @relation(fields: [userId], references: [id], onDelete: Cascade)
  category   Category    @relation(fields: [categoryId], references: [id])
  images     ItemImage[]
  tradeItems TradeItem[]
  favorites  Favorite[]
  chatRooms  ChatRoom[]

  // Performans indeksleri
  @@index([userId])
  @@index([categoryId])
  @@index([status])
  @@index([createdAt(sort: Desc)])
  @@map("items")
}

// ItemCondition: NEW, LIKE_NEW, GOOD, FAIR, POOR
// ItemStatus: ACTIVE, IN_TRADE, COMPLETED, PASSIVE, DELETED

// Bir ilanın birden fazla görseli - display_order ile sıralı
model ItemImage {
  id           String  @id @default(uuid())
  itemId       String  @map("item_id")
  imageUrl     String  @map("image_url") @db.VarChar(500)
  displayOrder Int     @default(0) @map("display_order")
  isPrimary    Boolean @default(false) @map("is_primary")
  createdAt    DateTime @default(now()) @map("created_at")

  // İlişkiler
  item Item @relation(fields: [itemId], references: [id], onDelete: Cascade)

  @@index([itemId])
  @@map("item_images")
}

// ============================================================
// 4. GELİŞMİŞ TAKAS MOTORU
// Çoklu ürün takasını destekler: 3 ürün + para karşılığı 1 ürün
// ============================================================

model Trade {
  id          String      @id @default(uuid())
  initiatorId String      @map("initiator_id")  // Teklif veren kullanıcı
  receiverId  String      @map("receiver_id")   // Teklif alan kullanıcı
  cashOffer   Float?      @map("cash_offer")    // Üste teklif edilen para (opsiyonel)
  status      String      @default("PENDING") @db.VarChar(50)
  note        String?     @db.Text              // Teklif notu
  createdAt   DateTime    @default(now()) @map("created_at")
  updatedAt   DateTime    @updatedAt @map("updated_at")

  // İlişkiler
  initiator  User        @relation("TradeInitiator", fields: [initiatorId], references: [id])
  receiver   User        @relation("TradeReceiver", fields: [receiverId], references: [id])
  tradeItems TradeItem[]
  chatRoom   ChatRoom?

  @@index([initiatorId])
  @@index([receiverId])
  @@index([status])
  @@map("trades")
}

// TradeStatus: PENDING, ACCEPTED, REJECTED, COMPLETED, CANCELLED, EXPIRED

// Takastaki her bir ürünü tutar
// side: OFFERED = teklif verenin ürünü, REQUESTED = teklif alanın ürünü
model TradeItem {
  id      String    @id @default(uuid())
  tradeId String    @map("trade_id")
  itemId  String    @map("item_id")
  side    String    @db.VarChar(50)

  // İlişkiler
  trade Trade @relation(fields: [tradeId], references: [id], onDelete: Cascade)
  item  Item  @relation(fields: [itemId], references: [id])

  @@unique([tradeId, itemId]) // Aynı ürün aynı takasta iki kez olamaz
  @@index([tradeId])
  @@map("trade_items")
}

// TradeSide: OFFERED, REQUESTED

// ============================================================
// 5. MESAJLAŞMA ALTYAPI (Chat)
// Oda tabanlı mesajlaşma - hem ilan bazlı hem takas bazlı
// ============================================================

model ChatRoom {
  id        String   @id @default(uuid())
  tradeId   String?  @unique @map("trade_id") // Takas bazlı oda (opsiyonel)
  itemId    String?  @map("item_id")           // İlan bazlı oda (opsiyonel)
  buyerId   String   @map("buyer_id")
  sellerId  String   @map("seller_id")
  isActive  Boolean  @default(true) @map("is_active")
  createdAt DateTime @default(now()) @map("created_at")

  // İlişkiler
  trade    Trade?    @relation(fields: [tradeId], references: [id])
  item     Item?     @relation(fields: [itemId], references: [id])
  buyer    User      @relation("ChatBuyer", fields: [buyerId], references: [id])
  seller   User      @relation("ChatSeller", fields: [sellerId], references: [id])
  messages Message[]

  @@index([buyerId])
  @@index([sellerId])
  @@map("chat_rooms")
}

model Message {
  id        String      @id @default(uuid())
  roomId    String      @map("room_id")
  senderId  String      @map("sender_id")
  content   String      @db.Text
  type      String      @default("TEXT") @db.VarChar(50)
  isRead    Boolean     @default(false) @map("is_read")
  createdAt DateTime    @default(now()) @map("created_at")

  // İlişkiler
  room   ChatRoom @relation(fields: [roomId], references: [id], onDelete: Cascade)
  sender User     @relation("MessageSender", fields: [senderId], references: [id])

  @@index([roomId])
  @@index([senderId])
  @@map("messages")
}

// MessageType: TEXT, IMAGE, SYSTEM_ALERT

// ============================================================
// 6. FAVORİLER
// ============================================================

model Favorite {
  userId    String   @map("user_id")
  itemId    String   @map("item_id")
  createdAt DateTime @default(now()) @map("created_at")

  // İlişkiler
  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
  item Item @relation(fields: [itemId], references: [id], onDelete: Cascade)

  @@id([userId, itemId]) // Bileşik birincil anahtar - aynı ilan iki kez favorilenemez
  @@map("favorites")
}
